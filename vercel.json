{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/monthly-invoices", "schedule": "0 7 * * *" },
    { "path": "/api/cron/subscription-ending", "schedule": "10 7 * * *" },
    {
      "path": "/api/cron/subscription-expired-followup",
      "schedule": "20 7 * * *"
    },
    {
      "path": "/api/cron/registration-no-subscription-followup",
      "schedule": "30 7 * * *"
    },
    { "path": "/api/cron/daily-todo-digest", "schedule": "0 8 * * *" },
    { "path": "/api/cron/appointment-reminders", "schedule": "*/15 * * * *" }
  ]
}
