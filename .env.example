# ============================================================
# Osago v2 — environment variables (TEMPLATE)
# ============================================================
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored and must NEVER be committed.
# In production, set these in Vercel → Settings → Environment Variables
# (same values for Production and Preview unless you intentionally use
#  separate Supabase projects).
#
# `NEXT_PUBLIC_*` vars are inlined into the browser bundle at build time —
# never put a secret behind that prefix. Everything else is server-only
# and only reachable from Server Components, Route Handlers, and Server Actions.
# ============================================================

# ── App ────────────────────────────────────────────────────────
# Base URL used to build absolute links/redirects (e.g. Supabase Auth
# recovery redirect, Mollie return/webhook URLs). Falls back to
# Vercel's own VERCEL_URL when unset in preview deployments.
APP_URL=http://localhost:3000

# ── Supabase — REQUIRED (auth, data, RLS) ───────────────────────
# Dashboard → Project Settings → API
# Public URL + anon key — safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Same project URL, server-side only (kept separate so it can never be
# imported from a client component by mistake).
SUPABASE_URL=
# Project API keys → service_role (SECRET). Server-only — bypasses all
# Row-Level Security. NEVER expose in the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare Turnstile — bot check on signup/login ────────────
# Site key is public (rendered in the widget); secret verifies server-side.
# Demo always-pass test keys: site 1x00000000000000000000AA,
# secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Twilio Verify — SMS OTP (2FA) ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ── Resend — transactional email ─────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@osago.nl
RESEND_FROM_NAME=Osago
# Set to 1 in local/dev to log emails instead of sending them.
# Must NOT be set to 1 in production — mail is silently dropped otherwise.
EMAIL_SIMULATOR=0

# ── Mollie — payments ─────────────────────────────────────────────
# Mode (live/test) is derived from the key prefix (live_ / test_).
MOLLIE_API_KEY=

# ── KvK — Dutch company register lookup ──────────────────────────
KVK_API_KEY=

# ── Anthropic (Claude) — AI generate/rewrite, extraction, matching ─
ANTHROPIC_API_KEY=

# ── Serper — Google web search (buyer matching) ──────────────────
SERPER_API_KEY=

# ── Unsplash — image picker (sales presentation) ──────────────────
UNSPLASH_ACCESS_KEY=

# ── Gamma — deck generation (IM/teaser/valuation), PDF/PPTX export ─
GAMMA_API_KEY=
GAMMA_OSAGO_THEME_ID=

# ── Cron auth — gates all /api/cron/* lifecycle jobs ──────────────
# Endpoints must fail closed (401) if this is unset.
CRON_SECRET=
